FACE_LIB_PATH=face_library
DB_FILE=db.json
# set 0.1 - 0.45 for better accuracy, but it may miss some matches. Adjust based on your needs.
THRESHOLD=0.4
MODEL_NAME=buffalo_l
MODEL_CTX=-1
WEBHOOK_URL=http://100.100.13.115:3001/webhook/detection
WORKER=4
SAVE_LIMIT=300

FACE_CROP_MARGIN=0.35
FACE_MIN_SIZE=5
FACE_DET_SCORE=0.65
FACE_MAX_ANGLE=70
FACE_BLUR_THRESHOLD=0.5

HC_YOLO_MODEL=yolov8n.pt 
HC_CONFIDENCE=25
HC_MODE_CCTV=true

#Variable	Fungsi
#FACE_CROP_MARGIN	memperbesar crop wajah
#FACE_MIN_SIZE	ukuran minimal bbox wajah
#FACE_DET_SCORE	confidence minimal deteksi
#FACE_MAX_ANGLE	batas kemiringan wajah